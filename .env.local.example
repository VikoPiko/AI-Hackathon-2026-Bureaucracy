# ============================================================
# BUREAUCRACYAI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# ============================================================

# --- Server-side Only (never prefix with NEXT_PUBLIC_) ---

# OpenAI API key for chat, structured output, web search, and embeddings
OPENAI_API_KEY=sk-your-openai-key-here

# Optional model overrides
# Defaults are chosen for quality-first production polishing.
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_SEARCH_MODEL=gpt-5.4-mini
OPENAI_ANALYZE_MODEL=gpt-5.4
OPENAI_JOURNEY_MODEL=gpt-5.5
OPENAI_COMPARE_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# UploadThing Secret (from uploadthing.com dashboard)
UPLOADTHING_SECRET=sk_live_your-uploadthing-secret-here

# --- Exposed to Browser ---

# UploadThing App ID (public, safe to expose)
NEXT_PUBLIC_UPLOADTHING_APP_ID=your-uploadthing-app-id

# App URL for server-side API calls
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable demo mode (shows pre-cached answers, skips API calls)
NEXT_PUBLIC_DEMO_MODE=true

# --- ChromaDB ---

# ChromaDB server URL
# Local development: http://localhost:8000
# Docker: http://localhost:8000
CHROMA_URL=http://localhost:8000

# --- Evaluation ---
# Run quality checks with: npm run eval:chat
